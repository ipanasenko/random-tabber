{
  "manifest_version": 3,
  "name": "Random Tabber",
  "version": "1.3.0",
  "description": "Jump to a random Chrome/Edge tab",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Random Tabber"
  },
  "commands": {
    "move-tab-to-prev-group": {
      "description": "Move selected tabs to the previous tab group",
      "suggested_key": {
        "default": "Ctrl+Shift+Comma",
        "mac": "MacCtrl+Command+Comma"
      }
    },
    "move-tab-to-next-group": {
      "description": "Move selected tabs to the next tab group",
      "suggested_key": {
        "default": "Ctrl+Shift+Period",
        "mac": "MacCtrl+Command+Period"
      }
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "permissions": ["storage", "tabGroups"]
}
